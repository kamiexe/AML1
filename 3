 import os 
import time 
import numpy as np 
os.environ['TF_CPP_MIN_LOG_LEVEL'] = '2' # Keep terminal clean 
import tensorflow as tf 
from tensorflow.keras import layers, models 
from tensorflow.keras.datasets import mnist 
from sklearn.metrics import precision_score, recall_score, f1_score 
 
def evaluate_model(model, X_test, y_test, model_name): 
    """Generates standard evaluation metrics for the given model.""" 
    predictions = model.predict(X_test, verbose=0) 
    y_pred = np.argmax(predictions, axis=1) 
     
    acc = np.mean(y_pred == y_test) 
    # Using 'macro' to average unweighted scores across all 10 digit classes 
    prec = precision_score(y_test, y_pred, average='macro') 
    rec = recall_score(y_test, y_pred, average='macro') 
    f1 = f1_score(y_test, y_pred, average='macro') 
     
    print(f"--- {model_name} Performance ---") 
    print(f"Accuracy:  {acc:.4f}") 
    print(f"Precision: {prec:.4f}") 
    print(f"Recall:    {rec:.4f}") 
    print(f"F1-Score:  {f1:.4f}\n") 
    return acc 
 
def run_experiment(): 
    print("="*70) 
    print(" HANDWRITING RECOGNITION: LSTM vs. Bi-LSTM") 
    print("="*70) 
 
    # 1. Load and Prepare MNIST Dataset 
    print("\n[1] Loading MNIST Dataset...") 
    (X_train, y_train), (X_test, y_test) = mnist.load_data() 
 
    # Normalize pixel values to be between 0 and 1 
    X_train = X_train.astype('float32') / 255.0 
    X_test = X_test.astype('float32') / 255.0 
 
    # For LSTMs, input shape must be (timesteps, features) 
    # Our images are 28x28, so: 28 timesteps (rows), 28 features (pixels per row) 
    input_shape = (28, 28) 
    print(f"Data reshaped to sequences. Shape: {X_train.shape}") 
 
    # 2. Build and Train Standard LSTM 
    print("\n[2] Building and Training Standard LSTM...") 
    lstm_model = models.Sequential([ 
        layers.Input(shape=input_shape), 
        layers.LSTM(128), # 128 memory units 
        layers.Dense(10, activation='softmax') 
    ]) 
     
    lstm_model.compile(optimizer='adam', loss='sparse_categorical_crossentropy', 
metrics=['accuracy']) 
     
    start_time = time.time() 
    lstm_model.fit(X_train, y_train, epochs=3, batch_size=64, validation_split=0.1, 
verbose=1) 
    lstm_time = time.time() - start_time 
 
    # 3. Build and Train Bidirectional LSTM (Bi-LSTM) 
    print("\n[3] Building and Training Bidirectional LSTM (Bi-LSTM)...") 
    bilstm_model = models.Sequential([ 
        layers.Input(shape=input_shape), 
        # Bidirectional wrapper doubles the LSTM layer (one forward, one backward) 
        layers.Bidirectional(layers.LSTM(128)),  
        layers.Dense(10, activation='softmax') 
    ]) 
     
    bilstm_model.compile(optimizer='adam', loss='sparse_categorical_crossentropy', 
metrics=['accuracy']) 
     
    start_time = time.time() 
    bilstm_model.fit(X_train, y_train, epochs=3, batch_size=64, validation_split=0.1, 
verbose=1) 
    bilstm_time = time.time() - start_time 
 
    # 4. Evaluation and Comparison 
    print("\n" + "="*70) 
    print(" EVALUATION MATRICES & COMPARISON") 
    print("="*70) 
     
    evaluate_model(lstm_model, X_test, y_test, "Standard LSTM") 
    evaluate_model(bilstm_model, X_test, y_test, "Bidirectional LSTM") 
     
    print("--- Training Time Comparison (3 Epochs) ---") 
    print(f"Standard LSTM Time: {lstm_time:.2f} seconds") 
    print(f"Bi-LSTM Time:       {bilstm_time:.2f} seconds") 
 
if __name__ == "__main__": 
    run_experiment()
