    print(f"Data shapes -> X_train: {X_train.shape}, y_train: {y_train.shape}") 
 
    # 2. Initialize and Train the Model 
    print("\n[2] Initializing Network (Inputs: 2, Hidden Nodes: 16, Outputs: 1)") 
    # High learning rate used here to speed up convergence on the simple dataset 
    model = DeepNeuralNetwork(input_size=2, hidden_size=16, output_size=1, 
learning_rate=0.5) 
    model.train(X_train, y_train, epochs=2500) 
 
    # 3. Predict on Test Set 
    print("[3] Validating Model Performance on Unseen Test Data...") 
