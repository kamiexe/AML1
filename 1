    print(f"Precision: {prec:.4f} (True Positives / All Predicted Positives)") 
    print(f"Recall:    {rec:.4f} (True Positives / All Actual Positives)") 
    print(f"F1-Score:  {f1:.4f} (Harmonic Mean of Precision & Recall)\n") 
     
    print("Detailed Classification Report Matrix:") 
    print(classification_report(y_test, y_pred)) 



